dat
# -- Fitting a lin model on "sigmoid" data. lol.
x = sort(dat$DR1TKCAL)
x
plot(x)
library(ggplot2)
ggplot(aes(x = x, y = 1:length(x)))
ggplot(aes(x = x, y = 1:length(x))) +
geom_step()
ggplot(aes(x = DR1TKCAL, y = 1:nrow(x)), data = dat) +
geom_step()
ggplot(aes(x = DR1TKCAL, y = 1:nrow(dat)), data = dat) +
geom_step()
dat |>
dplyr::arrange(DR1TKCAL) |>
ggplot(aes(x = DR1TKCAL, y = 1:nrow(dat))) +
geom_step()
ggplot(aes(x = DR1TKCAL, y = 1:nrow(dat) / (nrow(dat) + 1) ) +
# Empirische
dat |>
dplyr::arrange(DR1TKCAL) |>
ggplot(aes(x = DR1TKCAL, y = 1:nrow(dat) / (nrow(dat) + 1) )) +
geom_step()
# -- Fitting a lin model on "sigmoid" data. lol.
## Creating sigmoid data frame to ease working with the data
sdf = dat |>
# Empirische
sdf |>
ggplot(aes(x = DR1TKCAL, y = 1:nrow(dat) / (nrow(dat) + 1) )) +
geom_step()
# -- Fitting a lin model on "sigmoid" data. lol.
## Creating sigmoid data frame to ease working with the data
sdf = dat |>
dplyr::arrange(DR1TKCAL)
x = sort(dat$DR1TKCAL)
# Empirische
sdf |>
ggplot(aes(x = DR1TKCAL, y = 1:nrow(dat) / (nrow(dat) + 1) )) +
geom_step()
sdf
# -- Fitting a lin model on "sigmoid" data. lol.
## Creating sigmoid data frame to ease working with the data
sdf = dat |>
dplyr::arrange(DR1TKCAL) |>
dplyr::select(DR1TKCAL)
sdf
## Empirische CDF
sdf |>
ggplot(aes(x = DR1TKCAL, y = 1:nrow(dat) / (nrow(dat) + 1) )) +
geom_step()
# -- Fitting a lin model on "sigmoid" data. lol.
## Creating sigmoid data frame to ease working with the data
sdf = dat |>
dplyr::arrange(DR1TKCAL) |>
dplyr::select(DR1TKCAL) |>
dplyr::mutate(
ecdf = dplyr::row_number() / (nrow(dat) + 1)
)
sdf |>
ggplot(aes(x = DR1TKCAL, y =  ecdf)) +
geom_step()
sdf |>
ggplot(aes(x = DR1TKCAL, y =  e_lin)) +
geom_step()
# -- Fitting a lin model on "sigmoid" data. lol.
## Creating sigmoid data frame to ease working with the data
sdf = dat |>
dplyr::arrange(DR1TKCAL) |>
dplyr::select(DR1TKCAL) |>
dplyr::mutate(
# eCDF I refer to as sigmoid
e_sigmoid = dplyr::row_number() / (nrow(dat) + 1),
# Inverse the empirical sigmoid to obtain the "linear predictor"
e_lin = log(e_sigmoid / 1 - e_sigmoid)
)
sdf |>
ggplot(aes(x = DR1TKCAL, y =  ecdf)) +
geom_step()
# -- Fitting a lin model on "sigmoid" data. lol.
## Creating sigmoid data frame to ease working with the data
sdf = dat |>
dplyr::arrange(DR1TKCAL) |>
dplyr::select(DR1TKCAL) |>
dplyr::mutate(
# eCDF I refer to as sigmoid
e_sigmoid = dplyr::row_number() / (nrow(dat) + 1),
# Inverse the empirical sigmoid to obtain the "linear predictor"
e_lin = log(e_sigmoid / 1 - e_sigmoid)
)
sdf |>
ggplot(aes(x = DR1TKCAL, y =  ecdf)) +
geom_step()
sdf |>
ggplot(aes(x = DR1TKCAL, y =  e_sigmoid)) +
geom_step()
sdf |>
ggplot(aes(x = DR1TKCAL, y =  e_lin)) +
geom_step()
sdf |>
ggplot(aes(x = DR1TKCAL, y =  e_lin)) +
geom_point()
sdf
# -- Fitting a lin model on "sigmoid" data. lol.
## Creating sigmoid data frame to ease working with the data
sdf = dat |>
dplyr::arrange(DR1TKCAL) |>
dplyr::select(DR1TKCAL) |>
dplyr::mutate(
# eCDF I refer to as sigmoid
e_sigmoid = dplyr::row_number() / (nrow(dat) + 1),
# Inverse the empirical sigmoid to obtain the "linear predictor"
e_lin = log(e_sigmoid / (1 - e_sigmoid))
)
sdf |>
ggplot(aes(x = DR1TKCAL, y =  e_lin)) +
geom_point()
sdf |>
ggplot(aes(x = DR1TKCAL, y =  e_lin)) +
geom_step()
sdf |>
ggplot(aes(x = DR1TKCAL, y =  e_sigmoid)) +
geom_step()
sdf |>
ggplot(aes(x = DR1TKCAL, y =  e_lin)) +
geom_step()
sdf |>
ggplot(aes(x = DR1TKCAL, y =  e_sigmoid)) +
geom_step()
sdf |>
ggplot(aes(x = DR1TKCAL, y =  e_lin)) +
geom_step()
sdf |>
ggplot(aes(x = DR1TKCAL, y = e_lin)) +
geom_step() +
geom_smooth()
lm(e_lin ~ DR1TKCAL, dat = sdf)
lin_mdl = lm(e_lin ~ DR1TKCAL, dat = sdf)
lin_mdl = lm(e_lin ~ DR1TKCAL, dat = sdf)
summary(lin_mdl)
# Check fit
sdf$pred = predict(lin_mdl, newdata = sdf$DR1TKCAL)
# Check fit
sdf$pred = predict(lin_mdl, newdata = sdf)
sdf
sdf |>
ggplot(aes(x = DR1TKCAL)) +
geom_step(aes(y = e_lin)) +
geom_line(aes(y = pred))
lin_mdl = lm(e_lin ~ log(DR1TKCAL), dat = sdf)
# Check fit
sdf$pred = predict(lin_mdl, newdata = sdf)
sdf |>
ggplot(aes(x = DR1TKCAL)) +
geom_step(aes(y = e_lin)) +
geom_line(aes(y = pred))
sdf |>
ggplot(aes(x = DR1TKCAL)) +
geom_step(aes(y = e_lin)) +
geom_line(aes(y = pred))
# Compare this to the eCDF / e_sigmoid data
sdf |>
dplyr::mutate(
pred_sigmoid = 1 / (1 + exp(-pred))
)
# Compare this to the eCDF / e_sigmoid data
sdf = sdf |>
dplyr::mutate(
pred_sigmoid = 1 / (1 + exp(-pred))
)
sdf |>
ggplot(aes(x = DR1TKCAL)) +
geom_step(aes(y = e_sigmoid))
sdf |>
ggplot(aes(x = DR1TKCAL)) +
geom_step(aes(y = e_sigmoid)) +
geom_line(aes(y = pred_sigmoid))
sdf |>
ggplot(aes(x = DR1TKCAL)) +
geom_step(aes(y = e_sigmoid)) +
geom_line(aes(y = pred_sigmoid), color = "red")
summary(lin_mdl)
# Fit looks decent?
# Just double checking the linear model to ensure that moving this to jax would work out. Roughly.
lm_func = function(x) -30 + 4 * log(x)
lm_func
sdf$compare_pred = lm_func(sdf$DR1TKCAL)
sdf |>
geom(aes(x = pred, y = compare_pred)) +
geom_point()
sdf |>
ggplot(aes(x = pred, y = compare_pred)) +
geom_point()
